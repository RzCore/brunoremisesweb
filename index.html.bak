<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />

    <title>Remises Bruno - Transporte Premium</title>
    <meta
      content="Servicio de transporte ejecutivo y de pasajeros en Chivilcoy. Más de 25 años de experiencia en viajes de corta, media y larga distancia."
      name="description"
    />
    <meta
      content="remises, transporte, chivilcoy, viajes, ejecutivo, aeropuerto, flota"
      name="keywords"
    />

    <link rel="icon" type="image/png" href="assets/img/favicon.png" />

    <!-- Bootstrap 5 -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Google Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- AOS Animation Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <!-- Swiper CSS -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css"
    />

    <!-- Vendor CSS Files -->
    <link
      href="assets/vendor/bootstrap-icons/bootstrap-icons.css"
      rel="stylesheet"
    />
    <link href="assets/vendor/boxicons/css/boxicons.min.css" rel="stylesheet" />
    <link href="assets/vendor/remixicon/remixicon.css" rel="stylesheet" />

    <!-- Template Main CSS File -->
    <link href="assets/css/style.css" rel="stylesheet" />
  </head>

  <body>
    <!-- ======= Header ======= -->
    <header id="header" class="fixed-top">
      <nav class="navbar navbar-expand-lg">
        <div class="container">
          <a class="navbar-brand" href="#hero">
            <img
              src="assets/img/Logo.jpg"
              alt="Remises Bruno"
              class="logo-img"
            />
            <span class="brand-text">Remises Bruno</span>
          </a>

          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNav"
          >
            <span class="navbar-toggler-icon"></span>
          </button>

          <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
              <li class="nav-item">
                <a class="nav-link active" href="#hero">Inicio</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#about">Nosotros</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#services">Servicios</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#fleet">Flota</a>
              </li>
              <li class="nav-item">
                <a
                  class="nav-link"
                  href="https://wa.me/+5492346416730?text=Hola,%20necesito%20un%20remis"
                  >Reservas</a
                >
              </li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <!-- ======= Hero Section ======= -->
    <section id="hero" class="hero-section">
      <div class="hero-background">
        <div class="hero-overlay"></div>
      </div>

      <!-- Road Animation Effect -->
      <div class="road-animation">
        <div class="highway">
          <div class="highway-lines">
            <div class="highway-line"></div>
            <div class="highway-line"></div>
            <div class="highway-line"></div>
            <div class="highway-line"></div>
            <div class="highway-line"></div>
            <div class="highway-line"></div>
            <div class="highway-line"></div>
            <div class="highway-line"></div>
          </div>
        </div>
      </div>

      <div class="container">
        <div class="row align-items-center min-vh-100">
          <div class="col-lg-6" data-aos="fade-right" data-aos-delay="200">
            <div class="hero-content">
              <h1 class="hero-title">
                <span class="gradient-text">Viajes que marcan</span><br />
                <span class="highlight-text">la diferencia</span>
              </h1>
              <p class="hero-subtitle">
                Seguridad y confort en cada trayecto, sin importar la distancia.
                Más de 25 años de experiencia en transporte premium.
              </p>
              <div class="hero-buttons">
                <a
                  href="https://wa.me/+5492346416730?text=Hola,%20necesito%20un%20remis"
                  class="btn btn-primary btn-lg whatsapp-btn"
                >
                  <i class="bi bi-whatsapp"></i>
                  Reservar Ahora
                </a>
                <a
                  href="#services"
                  class="btn btn-outline-light btn-lg scroll-btn"
                >
                  Nuestros Servicios
                </a>
              </div>

              <!-- Mobile Logo -->
              <div class="mobile-logo">
                <img
                  src="assets/img/Logo.jpg"
                  alt="Remises Bruno"
                  class="mobile-hero-logo"
                />
              </div>

              <div class="hero-stats">
                <div class="stat-item">
                  <span class="stat-number">25+</span>
                  <span class="stat-label">Años de Experiencia</span>
                </div>
                <div class="stat-item">
                  <span class="stat-number">10.000 +</span>
                  <span class="stat-label">Clientes Satisfechos</span>
                </div>
                <div class="stat-item">
                  <span class="stat-number">24/7</span>
                  <span class="stat-label">Disponibilidad</span>
                </div>
              </div>
            </div>
          </div>
          <div class="col-lg-6" data-aos="fade-left" data-aos-delay="400">
            <div class="hero-image">
              <img
                src="assets/img/Logo.jpg"
                alt="Remises Bruno"
                class="hero-logo"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="scroll-indicator" onclick="scrollToSection('#about')">
        <div class="scroll-text">Descubre más</div>
        <div class="scroll-arrow"></div>
      </div>
    </section>

    <!-- ======= About Section ======= -->
    <section id="about" class="about-section">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-6" data-aos="fade-right">
            <div class="about-image">
              <img
                src="assets/img/team/Logan-Frente.jpeg"
                alt="Nuestro Servicio"
                class="img-fluid rounded-4"
              />
              <div class="experience-badge">
                <span class="years">25</span>
                <span class="text">Años de<br />Experiencia</span>
              </div>
            </div>
          </div>
          <div class="col-lg-6" data-aos="fade-left" data-aos-delay="200">
            <div class="about-content">
              <div class="section-header">
                <span class="section-subtitle">Sobre Nosotros</span>
                <h2 class="section-title">Tu confianza es nuestra prioridad</h2>
              </div>
              <p class="about-text">
                Con más de 25 años de experiencia en el sector del transporte,
                Remises Bruno se ha consolidado como la opción confiable para
                viajes de corta, media y larga distancia en Chivilcoy y
                alrededores.
              </p>
              <div class="features-grid">
                <div class="feature-item">
                  <div class="feature-icon">
                    <i class="bi bi-award"></i>
                  </div>
                  <div class="feature-content">
                    <h4>Experiencia Comprobada</h4>
                    <p>Más de dos décadas brindando servicio de calidad</p>
                  </div>
                </div>
                <div class="feature-item">
                  <div class="feature-icon">
                    <i class="bi bi-shield-check"></i>
                  </div>
                  <div class="feature-content">
                    <h4>Seguridad Total</h4>
                    <p>
                      Conductores capacitados y vehículos en óptimas condiciones
                    </p>
                  </div>
                </div>
                <div class="feature-item">
                  <div class="feature-icon">
                    <i class="bi bi-clock"></i>
                  </div>
                  <div class="feature-content">
                    <h4>Puntualidad Garantizada</h4>
                    <p>Llegamos a tiempo, siempre</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ======= Services Section ======= -->
    <section id="services" class="services-section">
